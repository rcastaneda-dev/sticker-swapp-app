# =========================================
# APPLE TESTFLIGHT DEPLOYMENT
# Used by GitHub Actions to upload builds
# =========================================

APPSTORE_CONNECT_API_KEY=
APPSTORE_CONNECT_API_KEY_ID=
APPSTORE_CONNECT_ISSUER_ID=

# =========================================
# GOOGLE PLAY INTERNAL TRACK DEPLOYMENT
# Used by GitHub Actions to upload AAB
# =========================================

PLAY_SERVICE_ACCOUNT_JSON=

# =========================================
# ANDROID SIGNING
# Required for building release AAB
# =========================================

ANDROID_KEYSTORE=
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=
ANDROID_KEY_PASSWORD=

# =========================================
# IOS SIGNING
# Required for building IPA
# =========================================

IOS_CERTIFICATE=
IOS_CERTIFICATE_PASSWORD=
PROVISIONING_PROFILE=

# =========================================
# SUPABASE
# Used by the go service to connect to the database
# =========================================

SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=xxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxx
SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# =========================================
# ABLY
# Used by the go service to connect to the Ably
# =========================================

ABLY_API_KEY=xxxxx